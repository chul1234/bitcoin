# Root-level .gitignore for the entire workspace

# IDE specific files (Hidden from view)
.idea/
.vscode/
*.iws
*.iml
*.ipr

# Maven / Build artifacts
**/target/
**/build/
.mvn/wrapper/maven-wrapper.jar

# Project specific files (Preserving original rules)
HELP.md
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# Secrets (Ensuring high sensitivity)
**/application-secret.yml

# OS files
.DS_Store
Thumbs.db

# Exceptions
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/
